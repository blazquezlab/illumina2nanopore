{
   "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/blazquezlab/illumina2nanopore/master/nextflow_schema.json",
    "title": "illumina2nanopore/nanopore_pipeline_parameters",
    "description": "A pipeline to demultiplex, map, deduplicate and count target RNA sequences",
    "type": "object",
    "definitions": {
        "run_options": {
            "title": "run_options",
            "type": "object",
            "description": "",
            "default": "",
            "properties": {
                "run_name": {
                    "type": "string",
                    "default": "run_test",
                    "description": ""
                },
                "output_dir": {
                    "type": "string",
                    "default": "output",
                    "format": "directory-path",
                    "description": ""
                }
            }
        },
        "basecalling_options": {
            "title": "basecalling_options",
            "type": "object",
            "description": "",
            "default": "",
            "properties": {
                "fastq_dir": {
                    "type": "string",
                    "default": "inputs/fastq",
                    "format": "directory-path",
                    "description": ""
                },
                "enable_basecalling": {
                    "type": "boolean",
                    "description": "",
                    "default": false
                },
                "enable_gpu": {
                    "type": "boolean",
                    "description": "",
                    "default": false
                },
                "fast5_dir": {
                    "type": "string",
                    "default": "inputs",
                    "description": "",
                    "format": "directory-path"
                },
                "config_file": {
                    "type": "string",
                    "default": "dna_r9.4.1_450bps_sup.cfg",
                    "description": "",
                    "format": "file-path"
                }
            }
        },
        "demultiplexing": {
            "title": "demultiplexing",
            "type": "object",
            "description": "",
            "default": "",
            "properties": {
                "enable_orientation_demultiplexing": {
                    "type": "boolean",
                    "default": true,
                    "description": ""
                },
                "fw_fp_P5_1": {
                    "type": "string",
                    "default": "AATGATACGGCGACCACCGAGATCTACACTCTTTCCCTA",
                    "description": ""
                },
                "rv_tp_P5_1": {
                    "type": "string",
                    "default": "TAGGGAAAGAGTGTAGATCTCGGTGGTCGCCGTATCATT",
                    "description": ""
                },
                "fw_tp_P3_1": {
                    "type": "string",
                    "default": "ATCTCGTATGCCGTCTTCTGCTTG",
                    "description": ""
                },
                "rv_fp_P3_1": {
                    "type": "string",
                    "default": "CAAGCAGAAGACGGCATACGAGAT",
                    "description": ""
                },
                "enable_library_demultiplexing": {
                    "type": "boolean",
                    "default": true,
                    "description": ""
                },
                "lib_csv": {
                    "type": "string",
                    "default": "inputs/csvs/libraries.csv",
                    "format": "file-path",
                    "description": ""
                },
                "fw_P5_2": {
                    "type": "string",
                    "default": "CACGACGCTCTTCCGATCT",
                    "description": ""
                },
                "fw_P3_2": {
                    "type": "string",
                    "default": "AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC",
                    "description": ""
                },
                "min_length": {
                    "type": "integer",
                    "default": 0,
                    "description": ""
                },
                "max_length": {
                    "type": "integer",
                    "default": 999999,
                    "description": ""
                },
                "enable_barcode_demultiplexing": {
                    "type": "boolean",
                    "default": true,
                    "description": ""
                },
                "bc_csv": {
                    "type": "string",
                    "default": "inputs/csvs/barcodes.csv",
                    "format": "file-path",
                    "description": ""
                },
                "enable_UMI_treatment": {
                    "type": "boolean",
                    "default": true,
                    "description": ""
                },
                "enable_UMI_clustering": {
                    "type": "boolean",
                    "default": false,
                    "description": ""
                },
                "UMI_length": {
                    "type": "integer",
                    "default": 6,
                    "description": "Length of the UMI (Unique Molecular Identifier) to be used."
                },
                "UMI_threshold": {
                    "type": "integer",
                    "default": 1,
                    "description": "Threshold for UMI clustering."
                },
                "window_size": {
                    "type": "integer",
                    "default": 5,
                    "description": "Window size for UMI clustering."
                }
            }
        },
        "alignment_options": {
            "title": "alignment_options",
            "type": "object",
            "description": "",
            "default": "",
            "properties": {
                "index_dir": {
                    "type": "string",
                    "default": "inputs/index",
                    "format": "directory-path",
                    "description": ""
                },
                "enable_minimap": {
                    "type": "boolean",
                    "default": true,
                    "description": ""
                },
                "ref_fasta": {
                    "type": "string",
                    "default": "inputs/fasta/reference.fa",
                    "format": "file-path",
                    "description": ""
                },
                "enable_isoform_counting": {
                    "type": "boolean",
                    "default": false,
                    "description": ""
                },
                "gtf_file": {
                    "type": "string",
                    "default": "inputs/index/annotations.gtf",
                    "format": "file-path",
                    "description": ""
                },
                "saf_file": {
                    "type": "string",
                    "default": "inputs/csvs/annotations.saf",
                    "format": "file-path",
                    "description": ""
                },
                "multimapping_allowed": {
                    "type": "boolean",
                    "default": false,
                    "description": ""
                },
                "fraction_allowed": {
                    "type": "boolean",
                    "default": false,
                    "description": ""
                }
            }
        }
    },
    "properties": {
        "multiqc_config": {
            "type": "string",
            "default": "assets/multiqc_config.yaml",
            "hidden": true
        }
    },
    "allOf": [
        {
            "$ref": "#/definitions/run_options"
        },
        {
            "$ref": "#/definitions/basecalling_options"
        },
        {
            "$ref": "#/definitions/demultiplexing"
        },
        {
            "$ref": "#/definitions/alignment_options"
        }
    ]
}
